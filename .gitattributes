# Auto detect text files and force LF line endings
* text=auto eol=lf

# Explicitly set LF for these file types
*.py text eol=lf
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.cfg text eol=lf
*.conf text eol=lf
*.ini text eol=lf
*.service text eol=lf

# Binary files
*.mp4 binary
*.png binary
*.jpg binary
*.ico binary